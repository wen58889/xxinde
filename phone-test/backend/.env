DATABASE_URL=sqlite+aiosqlite:///./test.db
JWT_SECRET_KEY=dev-secret-key-change-in-production
# 设备IP范围（只扫描实际存在的N1盒子，不要设太大否则会打坏macOS网络栈）
DEVICE_IP_START=192.168.5.101
DEVICE_IP_END=192.168.5.103
# 手机屏幕裁剪区域 (x1,y1,x2,y2)，对应相机图旋转后720x1280坐标系
# 裁剪到只含手机屏幕的矩形，让模板匹配只看屏幕内容
SCREEN_CROP=129,127,663,1272
# OpenCV 模板匹配阈值 (0.0~1.0)
TEMPLATE_MATCH_THRESHOLD=0.85
# 模板图标存储目录 (相对于backend/目录)
TEMPLATE_ICONS_DIR=../templates/icons
# PaddleOCR 语言
OCR_LANG=ch
